<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label id="titulo-principal" text="ReciApp" />
      <TabPane prefHeight="550.0" prefWidth="500.0" tabClosingPolicy="UNAVAILABLE">
         <tabs>
            <Tab text="Scan">
               <content>
                  <fx:include source="scan_tab.fxml" />
               </content>
            </Tab>
            <Tab text="Informes">
               <content>
                  <VBox alignment="CENTER" prefHeight="400.0" prefWidth="780.0">
                     <Label style="-fx-font-size: 18px; -fx-text-fill: #888888;" text="Informes - Coming soon" />
                  </VBox>
               </content>
            </Tab>
         </tabs>
      </TabPane>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
