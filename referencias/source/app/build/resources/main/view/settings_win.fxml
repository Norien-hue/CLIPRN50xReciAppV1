<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="350.0" prefWidth="320.0" spacing="15.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.javafx.reciWins.controllers.SettingsController">
   <children>
      <VBox prefHeight="54.0" prefWidth="300.0">
         <children>
            <Label id="label-nombre" text="Nombre">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <TextField fx:id="txtFld_nombre" prefWidth="300.0" />
         </children>
      </VBox>
      <VBox layoutX="20.0" layoutY="20.0" prefHeight="54.0" prefWidth="300.0">
         <children>
            <Label id="label-contrasena" text="Contraseña">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <Button fx:id="btn_passwd" mnemonicParsing="true" onAction="#launch_cambiarPwd" prefWidth="300.0" text="Cambiar contrase_ña">
               <tooltip>
                  <Tooltip text="Abrir ventana para cambiar la contraseña de la cuenta" />
               </tooltip>
            </Button>
         </children>
      </VBox>
      <VBox layoutX="20.0" layoutY="90.0" prefHeight="70.0" prefWidth="300.0">
         <children>
            <Label id="label-tap" text="TAP">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <HBox spacing="10.0">
               <children>
                  <TextField fx:id="txtFld_tap" prefWidth="220.0" editable="false" />
                  <Button fx:id="btn_mostrarTap" mnemonicParsing="true" onAction="#alternarMostrarTap" prefWidth="70.0" text="_Mostrar">
                     <tooltip>
                        <Tooltip text="Mostrar u ocultar el código TAP personal" />
                     </tooltip>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
      <HBox alignment="BOTTOM_RIGHT" prefHeight="100.0" prefWidth="300.0" spacing="10.0">
         <children>
            <Button fx:id="btn_accept" mnemonicParsing="true" onAction="#guardarCambios" text="_Guardar cambios">
               <tooltip>
                  <Tooltip text="Guardar los cambios realizados en la configuración" />
               </tooltip>
            </Button>
            <Button fx:id="btn_cancel" mnemonicParsing="true" onAction="#kill" text="_Cancelar">
               <tooltip>
                  <Tooltip text="Cancelar y cerrar sin guardar cambios" />
               </tooltip>
            </Button>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>