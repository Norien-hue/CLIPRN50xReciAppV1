            <Label text="Material" />
            <ComboBox fx:id="materialesProducto" prefHeight="26.0" prefWidth="260.0" editable="false" />
         </children>
      </VBox>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="70.0" prefWidth="260.0">
