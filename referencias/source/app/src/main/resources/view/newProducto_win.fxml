<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="475.0" prefWidth="280.0" spacing="15.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.javafx.reciWins.controllers.NewProducto">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="43.0" prefWidth="260.0">
         <children>
            <Label text="Nombre" />
            <TextField fx:id="nombreProducto" prefHeight="26.0" prefWidth="260.0" />
         </children>
      </VBox>
      <VBox layoutX="10.0" layoutY="10.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="43.0" prefWidth="260.0">
         <children>
            <Label text="Código Barras" />
            <TextField fx:id="codigoBarrasProducto" prefHeight="26.0" prefWidth="260.0" />
         </children>
      </VBox>
      <VBox layoutX="10.0" layoutY="53.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="43.0" prefWidth="260.0">
         <children>
            <Label text="Tipo" />
            <ComboBox fx:id="tipoProducto" prefHeight="26.0" prefWidth="260.0" editable="true" />
         </children>
      </VBox>
      <VBox layoutX="20.0" layoutY="137.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="43.0" prefWidth="260.0">
         <children>
            <Label text="Emisiones" />
            <TextField fx:id="emisionesProducto" prefHeight="26.0" prefWidth="260.0" />
         </children>
      </VBox>
      <VBox layoutX="20.0" layoutY="196.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="43.0" prefWidth="260.0">
         <children>
            <Label text="Material" />
            <ComboBox fx:id="materialesProducto" prefHeight="26.0" prefWidth="260.0" editable="false" />
         </children>
      </VBox>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="43.0" prefWidth="260.0">
         <children>
            <Label text="Ruta imagen (opcional)" />
            <TextField fx:id="rutaImagenProducto" prefHeight="26.0" prefWidth="260.0" promptText="Ej: C:\imagenes\producto.png" />
         </children>
      </VBox>
      <HBox alignment="BOTTOM_RIGHT" prefHeight="75.0" prefWidth="260.0" spacing="10.0">
         <children>
            <Button fx:id="btn_aceptar" mnemonicParsing="true" onAction="#crearProducto" text="_Aceptar">
               <tooltip>
                  <Tooltip text="Crear el nuevo producto en el catálogo" />
               </tooltip>
            </Button>
            <Button fx:id="btn_cancelar" mnemonicParsing="true" onAction="#kill" text="_Cancelar">
               <tooltip>
                  <Tooltip text="Cancelar y cerrar sin crear el producto" />
               </tooltip>
            </Button>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>